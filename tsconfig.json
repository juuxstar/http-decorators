{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"lib": [
			"es2022"
		],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"target": "es2022",
		"types": [
			"node"
		],
		"useDefineForClassFields": false
	},
	"include": [
		"src/**/*.ts"
	]
}
